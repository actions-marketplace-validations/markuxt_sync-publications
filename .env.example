# OpenAlex Configuration
# Copy this file to .env.development (local) or .env (generic) and fill in
# your values. See README.md for details.

# ROR ID of your institution.
# Find yours at https://ror.org
ROR_ID=https://ror.org/03y4dt428

# Contact email for OpenAlex API requests.
# Required by OpenAlex's polite usage policy.
CONTACT_EMAIL=your-email@example.com

# Content directory path (relative to project root, or absolute).
# Member markdown files live under <CONTENT_DIR>/members (or set
# MEMBERS_DIR below). Publications are written to
# <CONTENT_DIR>/publications.
CONTENT_DIR=src

# Optional: override the members directory if your layout differs.
# Leave empty to use <CONTENT_DIR>/members.
MEMBERS_DIR=

# GitHub Actions output file (auto-set by the runner). Leave empty locally.
GITHUB_OUTPUT=
